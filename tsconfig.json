{
  "extends": "@tsconfig/react-native/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@assets/*": [
        "./src/shared/assets/*"
      ],
      "@components/*": [
        "./src/presentation/components/*"
      ],
      "@navigation/*": [
        "./src/main/navigation/*"
      ],
      "@screens/*": [
        "./src/presentation/screens/*"
      ],
      "@storage/*": [
        "./src/storage/*"
      ],
      "@theme/*": [
        "./src/shared/styles/*"
      ],
      "@utils/*": [
        "./src/shared/utils/*"
      ]
    },
    "types": [
      "@types/styled-components-react-native"
    ]
  },    

}
